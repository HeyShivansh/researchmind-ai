# =============================================================================
# ResearchMind AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then deploy with:
#   docker compose -f docker-compose.prod.yml up -d
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Must be set before deployment
# ---------------------------------------------------------------------------

# Google Gemini API key for generating text embeddings.
# Get one at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Secret key for JWT token signing.
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-secure-random-secret-key-in-production

# PostgreSQL password (automatically generated or set manually).
# Required for production; defaults to "researchmind" in dev if unset.
POSTGRES_PASSWORD=your-strong-postgres-password-here

# ---------------------------------------------------------------------------
# Backend — Application Settings
# ---------------------------------------------------------------------------

# Runtime environment: development | production | staging
# APP_ENV=production

# Enable debug mode (true | false)
# DEBUG=false

# HTTP server host and port
# HOST=0.0.0.0
# PORT=8000

# ---------------------------------------------------------------------------
# Backend — PostgreSQL Connection
# ---------------------------------------------------------------------------

# POSTGRES_USER=researchmind
# POSTGRES_DB=researchmind
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# Connection pool settings
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# DB_ECHO=false

# ---------------------------------------------------------------------------
# Backend — File Storage
# ---------------------------------------------------------------------------

# Root directory for uploaded PDF files
# STORAGE_ROOT=storage

# Maximum upload file size in megabytes
# MAX_UPLOAD_SIZE_MB=50

# ---------------------------------------------------------------------------
# Backend — Text Chunking
# ---------------------------------------------------------------------------

# Number of characters per chunk
# DEFAULT_CHUNK_SIZE=500

# Overlap between consecutive chunks (in characters)
# DEFAULT_CHUNK_OVERLAP=50

# ---------------------------------------------------------------------------
# Backend — Embedding Provider (Gemini)
# ---------------------------------------------------------------------------

# Embedding provider: gemini | ollama | baai
# EMBEDDING_PROVIDER=gemini

# Embedding model name
# EMBEDDING_MODEL=text-embedding-004

# Embedding vector dimension (must match the model's output)
# EMBEDDING_DIMENSION=768

# Ollama base URL (if EMBEDDING_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Backend — Qdrant Vector Store
# ---------------------------------------------------------------------------

# Qdrant server URL (use container name in Docker: http://qdrant:6333)
# QDRANT_URL=http://qdrant:6333

# Qdrant API key (optional, for authenticated instances)
# QDRANT_API_KEY=

# Qdrant collection name
# QDRANT_COLLECTION_NAME=researchmind

# Vector dimension (must match embedding dimension)
# QDRANT_VECTOR_DIMENSION=768

# ---------------------------------------------------------------------------
# Backend — Hybrid Retrieval
# ---------------------------------------------------------------------------

# Number of top results from semantic (vector) search
# HYBRID_SEMANTIC_TOP_K=10

# Number of top results from keyword (BM25) search
# HYBRID_KEYWORD_TOP_K=10

# Reciprocal Rank Fusion constant (higher = less penalty for low ranks)
# HYBRID_FUSION_K=60

# ---------------------------------------------------------------------------
# Backend — JWT Authentication
# ---------------------------------------------------------------------------

# JWT signing algorithm
# JWT_ALGORITHM=HS256

# Access token expiration in minutes
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration in days
# REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS allowed origins (comma-separated list of frontend URLs)
# CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ---------------------------------------------------------------------------
# Frontend — Build-time Variables
# ---------------------------------------------------------------------------

# Base URL of the backend API (used at build time by Next.js)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API timeout in milliseconds
# NEXT_PUBLIC_API_TIMEOUT=30000

# ---------------------------------------------------------------------------
# Docker — Port Mapping
# ---------------------------------------------------------------------------

# Host port for the backend (default: 8000)
# BACKEND_PORT=8000

# Host port for the frontend (default: 3000)
# FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# Docker — Resource Limits (optional)
# ---------------------------------------------------------------------------

# Memory limit for each service (e.g., 512m, 1g)
# POSTGRES_MEM_LIMIT=512m
# QDRANT_MEM_LIMIT=512m
# BACKEND_MEM_LIMIT=1g
# FRONTEND_MEM_LIMIT=512m
